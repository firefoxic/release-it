{
	"name": "@firefoxic/release-it",
	"description": "Bump, publish and release new version for npm package using pnpm",
	"version": "5.1.0",
	"license": "MIT",
	"author": {
		"name": "Sergey Artemov",
		"email": "firefoxic.dev@gmail.com"
	},
	"homepage": "https://github.com/firefoxic/release-it#readme",
	"bugs": {
		"url": "https://github.com/firefoxic/release-it/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/firefoxic/release-it.git"
	},
	"exports": null,
	"files": [],
	"bin": {
		"release-it": "release-it.sh"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=26.4",
			"onFail": "download"
		},
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.9",
			"onFail": "download"
		}
	},
	"keywords": [
		"cli",
		"automation",
		"npm",
		"package",
		"release",
		"version",
		"changelog",
		"git",
		"github"
	],
	"devDependencies": {}
}
